# ==============================================================================
# 1. HỆ ĐIỀU HÀNH & IDES CHUNG (Áp dụng toàn dự án)
# ==============================================================================
# Hệ điều hành
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# IntelliJ / Android Studio / WebStorm
*.iml
*.ipr
*.iws
.idea/

# Visual Studio Code (Đã bỏ chặn để tránh đẩy cấu hình cá nhân lên Git)
.vscode/

# Các file rác/Log khác
*.log
*.class
*.pyc
*.swp
.atom/
.build/
.buildlog/
.history
.svn/
migrate_working_dir/


# ==============================================================================
# 2. FRONTEND (FLUTTER) - Nằm trong thư mục Frontend/
# ==============================================================================
# QUAN TRỌNG: Sửa triệt để lỗi không nhận file build của Flutter
Frontend/build/

# Các file cấu hình và bộ nhớ đệm của Dart/Flutter
Frontend/.dart_tool/
Frontend/.flutter-plugins
Frontend/.flutter-plugins-dependencies
Frontend/.pub-cache/
Frontend/.pub/
Frontend/coverage/

# Flutter liên quan đến iOS / Android Studio
Frontend/doc/api/
Frontend/ios/Flutter/.last_build_id
Frontend/.swiftpm/
Frontend/android/app/debug
Frontend/android/app/release
Frontend/android/app/profile

# Ký tự và Obfuscation (Mã hóa code)
Frontend/app.*.symbols
Frontend/app.*.map.json


# ==============================================================================
# 3. BACKEND (NODE.JS) - Nằm trong thư mục backend/
# ==============================================================================
# Thư mục cài đặt thư viện Node.js
backend/node_modules/

# File log và cấu hình của npm/yarn/pnpm
backend/logs/
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/pnpm-debug.log*
backend/.pnpm-debug.log*

# Prisma & Supabase (Nằm bên trong backend/)
backend/prisma/*.db
backend/prisma/*.db-journal
backend/.supabase/
backend/supabase/.temp/
backend/supabase/functions/.env


# ==============================================================================
# 4. MÔI TRƯỜNG & BẢO MẬT (Chặn tất cả các file .env ở mọi cấp)
# ==============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
**/backend/.env
**/Frontend/.env