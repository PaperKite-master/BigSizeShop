generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("SUPABASE_DB_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName                       String           @map("full_name") @db.VarChar(100)
  email                          String           @unique @db.VarChar(255)
  password                       String           @db.VarChar(255)
  phone                          String?          @db.VarChar(20)
  avatar                         String?
  role                           String?          @default("USER") @db.VarChar(20)
  createdAt                      DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at                     DateTime?        @default(now()) @db.Timestamp(6)
  addresses                      addresses[]
  cart_items                     CartItem[]
  chats_chats_admin_idTousers    chats[]          @relation("chats_admin_idTousers")
  chats_chats_customer_idTousers chats[]          @relation("chats_customer_idTousers")
  messages                       Message[]
  notifications                  Notification[]
  orders                         Order[]
  voucher_usages                 voucher_usages[]

  @@map("users")
}

model Category {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique @db.VarChar(100)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  products   Product[]

  @@map("categories")
}

model Product {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId       String?            @map("category_id") @db.Uuid
  name             String             @db.VarChar(255)
  description      String?
  price            Decimal            @db.Decimal(12, 2)
  stock            Int?               @default(0)
  imageUrl         String?            @map("image_url")
  is_active        Boolean?           @default(true)
  createdAt        DateTime?          @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  cart_items       CartItem[]
  order_items      OrderItem[]
  product_images   product_images[]
  product_variants product_variants[]
  categories       Category?          @relation(fields: [categoryId], references: [id], onUpdate: NoAction)

  @@index([categoryId], map: "idx_products_category")
  @@map("products")
}

model CartItem {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  productId        String            @map("product_id") @db.Uuid
  quantity         Int               @default(1)
  created_at       DateTime?         @default(now()) @db.Timestamp(6)
  variant_id       String?           @db.Uuid
  products         Product           @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users            User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, productId])
  @@index([userId], map: "idx_cart_user")
  @@map("cart_items")
}

model Order {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  totalPrice     Decimal          @map("total_price") @db.Decimal(12, 2)
  status         String?          @default("PENDING") @db.VarChar(30)
  address        String
  paymentMethod  String?          @map("payment_method") @db.VarChar(50)
  paymentStatus  String?          @default("UNPAID") @map("payment_status") @db.VarChar(30)
  createdAt      DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  order_items    OrderItem[]
  users          User             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voucher_usages voucher_usages[]

  @@index([userId], map: "idx_orders_user")
  @@map("orders")
}

model OrderItem {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId          String            @map("order_id") @db.Uuid
  productId        String            @map("product_id") @db.Uuid
  quantity         Int
  price            Decimal           @db.Decimal(12, 2)
  variant_id       String?           @db.Uuid
  orders           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products         Product           @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("order_items")
}

model Message {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId   String    @map("chat_id") @db.Uuid
  senderId String    @map("sender_id") @db.Uuid
  content  String
  sentAt   DateTime? @default(now()) @map("sent_at") @db.Timestamp(6)
  chats    chats     @relation(fields: [chatId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users    User      @relation(fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([chatId], map: "idx_messages_chat")
  @@map("messages")
}

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  title      String    @db.VarChar(255)
  content    String
  isRead     Boolean?  @default(false) @map("is_read")
  created_at DateTime? @default(now()) @db.Timestamp(6)
  users      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_notifications_user")
  @@map("notifications")
}

model addresses {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  receiver_name  String    @db.VarChar(100)
  receiver_phone String    @db.VarChar(20)
  province       String?   @db.VarChar(100)
  district       String?   @db.VarChar(100)
  ward           String?   @db.VarChar(100)
  street_address String
  is_default     Boolean?  @default(false)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)
  users          User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_addresses_user")
}

model chats {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                    String    @db.Uuid
  admin_id                       String?   @db.Uuid
  created_at                     DateTime? @default(now()) @db.Timestamp(6)
  users_chats_admin_idTousers    User?     @relation("chats_admin_idTousers", fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_chats_customer_idTousers User      @relation("chats_customer_idTousers", fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages                       Message[]
}

model product_images {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id   String    @db.Uuid
  image_url    String
  is_thumbnail Boolean?  @default(false)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  products     Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_product_images_product")
}

model product_variants {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id   String      @db.Uuid
  variant_name String      @db.VarChar(100)
  sku          String?     @unique @db.VarChar(100)
  price        Decimal?    @db.Decimal(12, 2)
  stock        Int?        @default(0)
  image_url    String?
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  updated_at   DateTime?   @default(now()) @db.Timestamp(6)
  cart_items   CartItem[]
  order_items  OrderItem[]
  products     Product     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_product_variants_product")
}

model store_locations {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_name    String    @db.VarChar(255)
  address       String
  latitude      Float
  longitude     Float
  phone         String?   @db.VarChar(20)
  opening_hours String?   @db.VarChar(255)
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamp(6)
}

model voucher_usages {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucher_id String    @db.Uuid
  user_id    String    @db.Uuid
  order_id   String?   @db.Uuid
  used_at    DateTime? @default(now()) @db.Timestamp(6)
  orders     Order?    @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      User      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  vouchers   vouchers  @relation(fields: [voucher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_voucher_usage_user")
  @@index([voucher_id], map: "idx_voucher_usage_voucher")
}

model vouchers {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                 String           @unique @db.VarChar(50)
  title                String           @db.VarChar(255)
  description          String?
  discount_type        String           @db.VarChar(20)
  discount_value       Decimal          @db.Decimal(12, 2)
  minimum_order_amount Decimal?         @default(0) @db.Decimal(12, 2)
  maximum_discount     Decimal?         @db.Decimal(12, 2)
  quantity             Int?             @default(0)
  start_date           DateTime?        @db.Timestamp(6)
  end_date             DateTime?        @db.Timestamp(6)
  is_active            Boolean?         @default(true)
  created_at           DateTime?        @default(now()) @db.Timestamp(6)
  voucher_usages       voucher_usages[]
}
